{
	"name": "5etools",
	"author": "TheGiddyLimit",
	"version": "2.26.1",
	"license": "MIT",
	"description": "A site dedicated to making playing games with your friends as easy as possible.",
	"type": "module",
	"private": true,
	"scripts": {
		"version-bump": "npm version -m \"chore(version): bump\"",
		"gen": "node node/generate-all.js",
		"gen:search-index": "node node/generate-search-index.js",
		"gen:pages": "node node/generate-pages.js",
		"clean-jsons": "node node/clean-jsons.js",
		"test:js": "eslint .",
		"lint:js": "npm run test:js -- --fix",
		"lint:js:fast": "node node/lint-js-changed.js",
		"lint:js:single": "eslint -- ",
		"test:css:lint": "stylelint scss/*.scss scss/includes/*.scss",
		"test:css:format": "echo '(Skipping CSS format check)'",
		"test:css": "npm run test:css:lint && npm run test:css:format",
		"lint:css:lint": "npm run test:css:lint -- --fix",
		"lint:css:format": "npm run prettier:css -- --write",
		"lint:css": "npm run lint:css:format && npm run lint:css:lint",
		"test:data": "node test/test-all.js",
		"test:manual:credits": "node test/test-adventure-book-credits.js",
		"test:manual:homebrew-tags": "node test/test-homebrew-tags.js",
		"test:manual:page-numbers": "node test/test-adventure-book-pages.js",
		"test:manual:page-generator": "node test/test-page-generator.js",
		"test:manual:tags-future": "node test/test-tag-source-versions.js",
		"test:manual": "npm run test:manual:credits && npm run test:manual:page-numbers && npm run test:manual:page-generator && npm run test:manual:tags-future && npm run test:manual:homebrew-tags -- --dir \"../homebrew\"",
		"lint:data": "node node/prettify-data/prettify-data.js",
		"test:json": "node test/test-json.js",
		"test:tags": "node test/test-tags.js",
		"test:unit": "node --localstorage-file test/temp/localstorage.tmp --experimental-vm-modules node_modules/jest/bin/jest.js",
		"test": "npm run test:js && npm run test:unit && npm run test:css && npm run test:data",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:data",
		"build:css": "sass --style=compressed scss/:css/ && node node/rm.js css/includes/ css/vars/",
		"build:seo": "node node/generate-seo.js",
		"build:sw": "node node/build-sw.mjs",
		"build:sw:prod": "node node/build-sw.mjs prod",
		"build": "npm run clean-jsons && npm run gen && npm run build:css && npm run build:sw:prod",
		"preversion": "npm test",
		"version": "node node/version-bump.js",
		"serve:dev": "http-server -c-1 --cors --port 5050",
		"serve:dev:tls": "http-server -c-1 --cors --port 5051 --tls --cert certs-dev-only/throwaway-cert.pem --key certs-dev-only/throwaway-key.pem",
		"spellcheck:check-data": "node node/spellcheck.js",
		"spellcheck:check-data:fast": "node node/spellcheck.js --fast",
		"spellcheck:trust-data": "node node/spellcheck.js --trust",
		"spellcheck:trust-data:fast": "node node/spellcheck.js --fast --trust",
		"prettier:css": "prettier scss/**/*.scss --log-level warn"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/5etools-mirror-3/5etools-src"
	},
	"engines": {
		"node": ">=24"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"5etools-utils": "^0.15.17",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"commander": "^14.0.3",
		"cspell-lib": "^9.6.4",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.1",
		"globals": "^17.3.0",
		"handlebars": "^4.7.8",
		"http-server": "^14.1.1",
		"jest": "^30.2.0",
		"json-source-map": "^0.6.1",
		"prettier": "^3.8.1",
		"probe-image-size": "^7.2.3",
		"readline-sync": "^1.4.10",
		"sass": "^1.97.3",
		"sharp": "^0.34.5",
		"simple-git": "^3.32.1",
		"stylelint": "^17.3.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"tinybench": "^6.0.0",
		"workbox-cli": "^7.4.0"
	},
	"bugs": {
		"url": "https://github.com/5etools-mirror-3/5etools-src/issues"
	},
	"homepage": "https://github.com/5etools-mirror-3/5etools-src#readme",
	"directories": {
		"lib": "lib",
		"test": "test"
	}
}
