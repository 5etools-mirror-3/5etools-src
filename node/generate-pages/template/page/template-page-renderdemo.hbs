<!DOCTYPE html>
<html lang="en">

{{> "head" }}

<body>

{{> "overlayNoise" }}

{{> "adLhs" }}
{{> "adRhs" }}

<div class="viewport-wrapper">
	{{> "adLeaderboard" }}

	{{> "navbar" }}

	<div class="view-col-wrapper" data-cancer-id="cancer-wrapper">
		<div class="view-col no-print" id="wrp-jsoninput">
			<pre id="jsoninput" class="inputArea ace_editor"></pre>

			<div class="ve-split-v-center">
				<div>
					<button class="ve-btn ve-btn-default ve-btn-sm" id="btn-format">Format</button>
				</div>

				<div class="ve-flex-v-center">
					<select class="ve-form-control ve-input-sm ve-mr-2" id="sel-renderer">
						<option value="html">HTML</option>
						<option value="md">Markdown</option>
						<option value="cards">RPG Cards</option>
					</select>
					<button class="ve-btn ve-btn-default ve-btn-sm ve-mr-2" id="btn-render">Render</button>
					<button class="ve-btn ve-btn-default ve-btn-sm" id="btn-reset">Reset</button>
				</div>
			</div>
		</div>

		<div id="wrp-output" class="view-col">
			<div class="ve-code ve-mb-2 ve-p-2 ve-hidden alert alert-danger" id="message"></div>

			<table id="pagecontent" class="ve-w-100 ve-stats">
				<!-- populate with JS -->
			</table>
		</div>
	</div>
</div>

{{> "adFooter" }}

{{> "scripts" }}

</body>
</html>
