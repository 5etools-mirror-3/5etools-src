<!DOCTYPE html>
<html lang="en">

{{> "head" }}

<body>

{{> "overlayNoise" }}

{{> "adLeaderboard" }}

{{> "navbar" }}

{{> "adLhsScrollingPage" }}
{{> "adRhsScrollingPage" }}

<main class="container classes">
	<div class="row ve-flex ve-mobile-md__flex-col">
		<div class="ve-col-3 ve-mobile-md__col-12 ve-px-4" id="listcontainer">
			<div class="night__shadow-big">
				<div class="ve-lst__form-top" id="filter-search-group">
					<div class="ve-w-100 ve-relative">
						<input type="search" id="lst__search" autocomplete="off" autocapitalize="off" spellcheck="false" class="search ve-form-control ve-lst__search ve-lst__search--no-border-h">
						<div id="lst__search-glass" class="ve-lst__wrp-search-glass ve-no-events ve-flex-vh-center"><span class="glyphicon glyphicon-search"></span></div>
						<div class="ve-lst__wrp-search-visible ve-no-events ve-flex-vh-center"></div>
					</div>
					<button class="ve-btn ve-btn-default ve-px-2" id="reset"><span class="glyphicon glyphicon-refresh"></span></button>
				</div>
				<div id="filtertools" class="ve-input-group ve-input-group--bottom ve-flex ve-no-shrink">
					<button class="ve-col-8 sort ve-btn ve-btn-default ve-btn-xs" data-sort="name">Name</button>
					<button class="sort ve-btn ve-btn-default ve-btn-xs ve-grow" data-sort="source">Source</button>
				</div>

				<div class="list list--stats classes cls__list" id="list"></div>
			</div>

			<div class="ve-flex-vh-center ve-my-3">
				{{> "btngroupManager" }}
			</div>
		</div>
		<div class="ve-col-9 ve-mobile-md__col-12 ve-mobile-sm__overflow-x-auto ve-px-4" id="classtable"></div>
	</div>

	<hr class="ve-mt-0">

	<div class="row ve-flex ve-mobile-md__flex-col">
		<div class="ve-col-3 ve-mobile-md__col-12 ve-px-4">
			<div class="ve-flex-vh-center ve-text-center wrp-btn-readmode ve-mb-3">
				<button class="ve-btn ve-btn-default ve-btn-xs no-print ve-mr-1" id="btn-comparemode" title="A pop-up table which can be used to compare subclass features.">Subclass Comparison</button>
				<button class="ve-btn ve-btn-default ve-btn-xs no-print ve-mr-1" id="btn-readmode" title="A pop-up reading mode with a layout and content order matching that of the books.">Book View</button>
				<div class=" ve-flex-v-center ve-btn-group">
					<button class="ve-btn ve-btn-default ve-btn-xs" id="btn-link-export"><span class="glyphicon glyphicon-magnet"></span></button>
					<button class="ve-btn ve-btn-default ve-btn-xs" id="btn-sidebar-settings" title="Settings"><span class="glyphicon glyphicon-cog"></span></button>
				</div>
			</div>

			<div id="statsprof"></div>

			<div id="sticky-nav" class="cls-nav"></div>
		</div>
		<div class="ve-col-9 ve-mobile-md__col-12 ve-px-4">
			<div class="cancer__wrp-mobile-1 cancer__anchor"><div class="cancer__disp-cancer"></div><!--5ETOOLS_AD_MOB_PLAYER_1--></div>

			<div id="subclasstabs" class="ve-w-100 ve-flex ve-mb-2 cls-tabs__wrp"></div>
			<table id="pagecontent" class="ve-w-100 ve-stats shadow-big cls__stats">
				<tr><th class="ve-tbl-border" colspan="6"></th></tr>
				<tr><td colspan="6" class="initial-message initial-message--med">Loading...</td></tr>
				<tr><th class="ve-tbl-border" colspan="6"></th></tr>
			</table>
		</div>
	</div>
</main>

{{> "adFooter" }}

{{> "scripts" }}

</body>
</html>
