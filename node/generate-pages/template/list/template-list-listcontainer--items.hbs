<div class="view-col{{#if styleListContainerAdditional}} {{styleListContainerAdditional}}{{/if}}" id="listcontainer">
	<div class="ve-flex-col ve-min-h-0 ve-w-100 ve-itm__wrp-list ve-itm__wrp-list--empty ve-itm__wrp-list--mundane">
		<div class="ve-lst__form-top" id="filter-search-group">
			<div class="ve-w-100 ve-relative">
				<input type="search" id="lst__search" autocomplete="off" autocapitalize="off" spellcheck="false" class="search ve-form-control ve-lst__search ve-lst__search--no-border-h">
				<div id="lst__search-glass" class="ve-lst__wrp-search-glass ve-no-events ve-flex-vh-center"><span class="glyphicon glyphicon-search"></span></div>
				<div class="ve-lst__wrp-search-visible ve-no-events ve-flex-vh-center"></div>
			</div>
			<button type="button" class="ve-btn ve-btn-default" id="reset">Reset</button>
		</div>

		<div id="filtertools-mundane" class="ele-mundane ve-input-group ve-input-group--bottom ve-flex ve-no-shrink">
			<button type="button" class="ve-col-3-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="name" data-sortby="asc">Name</button>
			<button type="button" class="ve-col-4-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="type" data-sortby="asc">Type</button>
			<button type="button" class="ve-col-1-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="cost" data-sortby="asc">Cost</button>
			<button type="button" class="ve-col-1-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="weight" data-sortby="asc">Weight</button>
			<button type="button" class="sort ve-btn ve-btn-default ve-btn-xs ve-grow" data-sort="source" data-sortby="asc">Source</button>
		</div>

		<div class="list list--stats mundane ele-mundane" id="list-mundane"></div>
		<h3 class="ele-mundane"><span class="side-label side-label--mundane ve-clickable"></span></h3>
	</div>

	<div class="ve-flex-col ve-min-h-0 ve-w-100 ve-itm__wrp-list ve-itm__wrp-list--empty ve-itm__wrp-list--magic">
		<div class="ve-no-shrink ve-itm__list-divider ele-mundane-and-magic"></div>

		<div id="filtertools-magic" class="ele-magic ve-input-group ve-input-group--bottom ve-flex ve-no-shrink">
			<button type="button" class="fullborder ve-col-3-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="name" data-sortby="asc">Name</button>
			<button type="button" class="fullborder ve-col-4 sort ve-btn ve-btn-default ve-btn-xs" data-sort="type" data-sortby="asc">Type</button>
			<button type="button" class="fullborder ve-col-1-5 sort ve-btn ve-btn-default ve-btn-xs" data-sort="weight" data-sortby="asc">Weight</button>
			<button type="button" class="ve-col-0-6 sort ve-btn ve-btn-default ve-btn-xs" data-sort="attunement" title="Can Be Attuned">A.</button>
			<button type="button" class="fullborder ve-col-1-4 sort ve-btn ve-btn-default ve-btn-xs" data-sort="rarity" data-sortby="asc">Rarity</button>
			<button type="button" class="fullborder sort ve-btn ve-btn-default ve-btn-xs ve-grow" data-sort="source" data-sortby="asc">Source</button>
		</div>

		<div class="list list--stats magic ele-magic" id="list-magic"></div>
		<h3 class="ele-magic"><span class="side-label side-label--magic ve-clickable"></span></h3>
	</div>
</div>
